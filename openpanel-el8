#!/bin/bash
set -euo pipefail

LANG=en_US.UTF-8
export LANG

GITHUB_REPO="https://github.com/WebOpenPanel/openpanel.git"
INSTALL_DIR="/usr/local/openpanel"
PHP_VERSION="8.3"
DB_NAME="open_panel"
DB_USER="openpanel"
LOG_FILE="/tmp/openpanel-el8-install.log"
REQUIRED_RAM_MB=512

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log()  { echo -e "${GREEN}[OpenPanel]${NC} $1" | tee -a "$LOG_FILE"; }
warn() { echo -e "${YELLOW}[WARNING]${NC} $1" | tee -a "$LOG_FILE"; }
err()  { echo -e "${RED}[ERROR]${NC} $1" | tee -a "$LOG_FILE"; exit 1; }
step() { echo -e "\n${BLUE}========================================${NC}" | tee -a "$LOG_FILE"; echo -e "${BLUE}  $1${NC}" | tee -a "$LOG_FILE"; echo -e "${BLUE}========================================${NC}\n" | tee -a "$LOG_FILE"; }

check_root() {
    [[ $EUID -ne 0 ]] && err "Must run as root: sudo bash $0"
}

validate_el8() {
    [ -f /etc/os-release ] || err "/etc/os-release not found"
    . /etc/os-release
    OS_MAJOR="${VERSION_ID%%.*}"
    arch=$(uname -m)

    [[ "$arch" != "x86_64" ]] && err "Unsupported arch: $arch (need x86_64)"

    case "$OS_MAJOR" in
        8)  ;;
        *)  err "This installer requires EL8 (RHEL/CentOS/AlmaLinux/Rocky/Oracle 8.x). Detected: $PRETTY_NAME" ;;
    esac

    log "Validated: $PRETTY_NAME on $arch"
}

check_existing() {
    if [ -d "$INSTALL_DIR" ] && [ -f "$INSTALL_DIR/artisan" ]; then
        warn "OpenPanel already installed at $INSTALL_DIR"
        read -p "Reinstall/upgrade? (y/N): " confirm
        [[ ! "$confirm" =~ ^[Yy]$ ]] && exit 0
    fi
}

check_resources() {
    local ram_mb=$(free -m | awk '/^Mem:/{print $2}')
    [[ "$ram_mb" -lt "$REQUIRED_RAM_MB" ]] && err "RAM: ${ram_mb}MB < ${REQUIRED_RAM_MB}MB required"
    log "RAM: ${ram_mb}MB OK"
}

gather_config() {
    echo ""
    echo -e "${BLUE}=== OpenPanel EL8 Installation ===${NC}"
    echo ""

    read -p "MySQL root password (blank=auto-generate): " MYSQL_ROOT_PASSWORD
    [ -z "$MYSQL_ROOT_PASSWORD" ] && MYSQL_ROOT_PASSWORD=$(openssl rand -base64 16 | tr -dc A-Za-z0-9 | head -c 20) && log "Generated MySQL root pwd: $MYSQL_ROOT_PASSWORD"

    DB_PASSWORD=$(openssl rand -base64 16 | tr -dc A-Za-z0-9 | head -c 20)

    read -p "Admin username [admin]: " ADMIN_USER
    ADMIN_USER="${ADMIN_USER:-admin}"

    read -p "Admin email [admin@$(hostname -f 2>/dev/null || hostname)]: " ADMIN_EMAIL
    ADMIN_EMAIL="${ADMIN_EMAIL:-admin@$(hostname -f 2>/dev/null || hostname)}"

    read -s -p "Admin password (blank=auto-generate): " ADMIN_PASSWORD
    echo ""
    [ -z "$ADMIN_PASSWORD" ] && ADMIN_PASSWORD=$(openssl rand -base64 12 | tr -dc A-Za-z0-9 | head -c 16) && log "Generated admin pwd: $ADMIN_PASSWORD"

    read -p "Server IP (auto-detect): " SERVER_IP
    [ -z "$SERVER_IP" ] && SERVER_IP=$(curl -4 -s --connect-timeout 5 ifconfig.me 2>/dev/null || ip -4 addr show scope global | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | head -1)
    log "Server IP: $SERVER_IP"

    read -p "Install CSF firewall? (Y/n): " INSTALL_CSF; INSTALL_CSF="${INSTALL_CSF:-Y}"
    read -p "Install mail server? (Y/n): " INSTALL_MAIL; INSTALL_MAIL="${INSTALL_MAIL:-Y}"
    read -p "Reboot after install? (y/N): " DO_RESTART; DO_RESTART="${DO_RESTART:-N}"
}

install_repos() {
    step "Configuring Repositories (EL8)"
    dnf -y install epel-release 2>&1 | tee -a "$LOG_FILE"

    dnf config-manager --set-enabled powertools 2>&1 | tee -a "$LOG_FILE" || true
    if [ -f /etc/yum.repos.d/almalinux-powertools.repo ]; then
        sed -i 's/enabled=0/enabled=1/' /etc/yum.repos.d/almalinux-powertools.repo
    fi
    if [ -f /etc/yum.repos.d/Rocky-PowerTools.repo ]; then
        sed -i 's/enabled=0/enabled=1/' /etc/yum.repos.d/Rocky-PowerTools.repo
    fi
    if [ -f /etc/yum.repos.d/Rocky-Linux-PowerTools.repo ]; then
        sed -i 's/enabled=0/enabled=1/' /etc/yum.repos.d/Rocky-Linux-PowerTools.repo
    fi
    if [ -f /etc/yum.repos.d/CentOS-PowerTools.repo ]; then
        sed -i 's/enabled=0/enabled=1/' /etc/yum.repos.d/CentOS-PowerTools.repo
        sed -i 's/\[PowerTools\]/\[powertools\]/' /etc/yum.repos.d/CentOS-PowerTools.repo
    fi
    if [ -f /etc/yum.repos.d/CentOS-Stream-PowerTools.repo ]; then
        sed -i 's/enabled=0/enabled=1/' /etc/yum.repos.d/CentOS-Stream-PowerTools.repo
    fi

    dnf -y install https://rpms.remirepo.net/enterprise/remi-release-8.rpm 2>&1 | tee -a "$LOG_FILE" || true
    dnf -y makecache 2>&1 | tee -a "$LOG_FILE"
    log "Repositories ready"
}

install_php() {
    step "Installing PHP $PHP_VERSION"
    dnf -y module reset php 2>&1 | tee -a "$LOG_FILE"
    dnf -y module enable php:remi-${PHP_VERSION} 2>&1 | tee -a "$LOG_FILE"
    dnf -y install php php-cli php-common php-fpm php-mysqlnd php-pdo php-mbstring php-xml \
        php-bcmath php-json php-tokenizer php-zip php-curl php-gd php-intl php-opcache \
        php-soap php-redis php-imagick php-ldap php-sodium php-fileinfo php-ctype php-dom \
        php-phar php-readline php-posix 2>&1 | tee -a "$LOG_FILE"

    command -v php &>/dev/null || err "PHP install failed"

    cat > /etc/php.d/99-openpanel.ini <<'EOPHP'
date.timezone = UTC
short_open_tag = On
max_execution_time = 300
max_input_time = 300
memory_limit = 512M
post_max_size = 512M
upload_max_filesize = 512M
expose_php = Off
display_errors = Off
log_errors = On
opcache.enable = 1
opcache.memory_consumption = 128
opcache.interned_strings_buffer = 8
opcache.max_accelerated_files = 10000
EOPHP

    log "PHP $(php -r 'echo PHP_VERSION;') installed"
}

install_nginx() {
    step "Installing Nginx"
    dnf -y install nginx 2>&1 | tee -a "$LOG_FILE"
    command -v nginx &>/dev/null || err "Nginx install failed"
    log "Nginx installed"
}

install_mariadb() {
    step "Installing MariaDB"

    if [ -e "/etc/systemd/system/mariadb.service.d/override.conf" ] || systemctl is-active --quiet mariadb 2>/dev/null; then
        log "MariaDB service exists, checking status..."
    else
        dnf -y install mariadb-server mariadb 2>&1 | tee -a "$LOG_FILE"
        mkdir -p /etc/systemd/system/mariadb.service.d/
        cat > /etc/systemd/system/mariadb.service.d/override.conf <<'EOF'
[Service]
CapabilityBoundingSet=
AmbientCapabilities=
EOF
        systemctl daemon-reload
    fi

    systemctl enable mariadb && systemctl start mariadb
    systemctl is-active --quiet mariadb || err "MariaDB failed to start"

    if mysqladmin -u root status &>/dev/null 2>&1; then
        mysqladmin -u root password "$MYSQL_ROOT_PASSWORD" 2>&1 | tee -a "$LOG_FILE"
    else
        mysql -u root -p"$MYSQL_ROOT_PASSWORD" -e "SELECT 1;" &>/dev/null || err "MySQL connection failed"
    fi

    mysql -u root -p"$MYSQL_ROOT_PASSWORD" <<EOSQL
DELETE FROM mysql.user WHERE User='';
DELETE FROM mysql.user WHERE User='root' AND Host NOT IN ('localhost','127.0.0.1','::1');
DROP DATABASE IF EXISTS test;
DELETE FROM mysql.db WHERE Db='test' OR Db='test\\_%';
FLUSH PRIVILEGES;
CREATE DATABASE IF NOT EXISTS \`${DB_NAME}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS '${DB_USER}'@'localhost' IDENTIFIED BY '${DB_PASSWORD}';
GRANT ALL PRIVILEGES ON \`${DB_NAME}\`.* TO '${DB_USER}'@'localhost';
FLUSH PRIVILEGES;
EOSQL

    cat > /root/.my.cnf <<EOF
[client]
password=$MYSQL_ROOT_PASSWORD
user=root
EOF
    chmod 600 /root/.my.cnf
    log "MariaDB configured"
}

install_composer() {
    step "Installing Composer"
    if ! command -v composer &>/dev/null; then
        curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer 2>&1 | tee -a "$LOG_FILE"
    fi
    command -v composer &>/dev/null || err "Composer install failed"
    log "Composer installed"
}

install_nodejs() {
    step "Installing Node.js"
    if ! command -v node &>/dev/null; then
        curl -fsSL https://rpm.nodesource.com/setup_20.x | bash - 2>&1 | tee -a "$LOG_FILE"
        dnf -y install nodejs 2>&1 | tee -a "$LOG_FILE"
    fi
    command -v node &>/dev/null && log "Node.js $(node --version)" || warn "Node.js not available"
}

clone_and_setup() {
    step "Installing OpenPanel"
    [ -d "$INSTALL_DIR" ] && cp "$INSTALL_DIR/.env" "$INSTALL_DIR/.env.bak.$(date +%s)" 2>/dev/null || true

    if [ -d "$INSTALL_DIR/.git" ]; then
        cd "$INSTALL_DIR" && git pull origin main 2>&1 | tee -a "$LOG_FILE"
    else
        mkdir -p "$INSTALL_DIR"
        git clone "$GITHUB_REPO" "$INSTALL_DIR" 2>&1 | tee -a "$LOG_FILE"
        cd "$INSTALL_DIR"
    fi

    composer install --no-dev --optimize-autoloader --no-interaction 2>&1 | tee -a "$LOG_FILE"

    cat > "$INSTALL_DIR/.env" <<EOF
APP_NAME="OpenPanel"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://${SERVER_IP}:2087
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=${DB_NAME}
DB_USERNAME=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=25
MAIL_FROM_ADDRESS="noreply@$(hostname -f 2>/dev/null || hostname)"
MAIL_FROM_NAME="OpenPanel"
EOF

    php artisan key:generate --force 2>&1 | tee -a "$LOG_FILE"
    php artisan migrate --force 2>&1 | tee -a "$LOG_FILE"

    php artisan tinker --execute="
        \\App\\Models\\User::updateOrCreate(
            ['username' => '${ADMIN_USER}'],
            ['email' => '${ADMIN_EMAIL}', 'password' => bcrypt('${ADMIN_PASSWORD}'), 'role' => 'admin', 'status' => 'active', 'ip_address' => '${SERVER_IP}']
        );
    " 2>&1 | tee -a "$LOG_FILE"

    if command -v npm &>/dev/null; then
        npm install --ignore-scripts 2>&1 | tee -a "$LOG_FILE"
        npm run build 2>&1 | tee -a "$LOG_FILE"
    fi

    php artisan config:cache 2>&1 | tee -a "$LOG_FILE"
    php artisan route:cache 2>&1 | tee -a "$LOG_FILE"
    php artisan view:cache 2>&1 | tee -a "$LOG_FILE"
    php artisan storage:link 2>&1 | tee -a "$LOG_FILE"

    chown -R nginx:nginx "$INSTALL_DIR/storage" "$INSTALL_DIR/bootstrap/cache"
    chmod -R 775 "$INSTALL_DIR/storage" "$INSTALL_DIR/bootstrap/cache"
}

configure_services() {
    step "Configuring Services"

    mkdir -p /etc/pki/tls/certs /etc/pki/tls/private
    openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
        -keyout /etc/pki/tls/private/openpanel.key \
        -out /etc/pki/tls/certs/openpanel.crt \
        -subj "/C=US/ST=California/L=SanFrancisco/O=OpenPanel/CN=${SERVER_IP}" \
        2>&1 | tee -a "$LOG_FILE"
    chmod 600 /etc/pki/tls/private/openpanel.key

    cat > /etc/nginx/conf.d/openpanel.conf <<'EONGX'
server {
    listen 2087 ssl http2;
    listen [::]:2087 ssl http2;
    server_name _;
    root /usr/local/openpanel/public;
    index index.php;

    ssl_certificate /etc/pki/tls/certs/openpanel.crt;
    ssl_certificate_key /etc/pki/tls/private/openpanel.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    client_max_body_size 512M;
    client_body_timeout 300;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;

    location / { try_files $uri $uri/ /index.php?$query_string; }

    location ~ \.php$ {
        fastcgi_pass unix:/run/php-fpm/www.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_read_timeout 300;
    }

    location ~ /\.(?!well-known).* { deny all; }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
EONGX

    if [ -f /etc/php-fpm.d/www.conf ]; then
        sed -i 's/^user = apache/user = nginx/' /etc/php-fpm.d/www.conf
        sed -i 's/^group = apache/group = nginx/' /etc/php-fpm.d/www.conf
        sed -i 's|^listen = .*|listen = /run/php-fpm/www.sock|' /etc/php-fpm.d/www.conf
        sed -i 's/^;listen.owner = nobody/listen.owner = nginx/' /etc/php-fpm.d/www.conf
        sed -i 's/^;listen.group = nobody/listen.group = nginx/' /etc/php-fpm.d/www.conf
        sed -i 's/^pm.max_children = .*/pm.max_children = 50/' /etc/php-fpm.d/www.conf
    fi

    mkdir -p /run/php-fpm && chown nginx:nginx /run/php-fpm
    systemctl enable php-fpm && systemctl restart php-fpm
    nginx -t 2>&1 | tee -a "$LOG_FILE" || err "Nginx config test failed"
    systemctl enable nginx && systemctl restart nginx

    cat > /etc/cron.d/openpanel <<EOF
* * * * * cd ${INSTALL_DIR} && php artisan schedule:run >> /var/log/openpanel-schedule.log 2>&1
0 2 * * * cd ${INSTALL_DIR} && php artisan cache:clear >> /var/log/openpanel-cache.log 2>&1
EOF
    chmod 0644 /etc/cron.d/openpanel

    log "Services configured"
}

install_csf() {
    [[ ! "$INSTALL_CSF" =~ ^[Yy]$ ]] && return
    step "Installing CSF Firewall"
    cd /tmp && rm -rf csf csf.tgz
    wget -q http://static.cdn-cwp.com/files/csf.tgz 2>&1 | tee -a "$LOG_FILE"
    tar -xzf csf.tgz && cd csf && sh install.sh 2>&1 | tee -a "$LOG_FILE"
    sed -i 's|TESTING = "1"|TESTING = "0"|' /etc/csf/csf.conf
    sed -i "s|80,110,113,443|80,110,113,443,2087|" /etc/csf/csf.conf
    csf -r 2>&1 | tee -a "$LOG_FILE"
    cd / && rm -rf /tmp/csf /tmp/csf.tgz
    log "CSF installed"
}

install_mail() {
    [[ ! "$INSTALL_MAIL" =~ ^[Yy]$ ]] && return
    step "Installing Mail Server"
    dnf -y install postfix dovecot dovecot-mysql dovecot-pigeonhole 2>&1 | tee -a "$LOG_FILE"
    POSTFIX_PASSWORD=$(openssl rand -base64 12 | tr -dc A-Za-z0-9 | head -c 16)
    HOSTNAME=$(hostname -f 2>/dev/null || hostname)
    mysql -u root -p"$MYSQL_ROOT_PASSWORD" <<EOSQL
CREATE DATABASE IF NOT EXISTS postfix CHARACTER SET utf8mb4;
CREATE USER IF NOT EXISTS 'postfix'@'localhost' IDENTIFIED BY '${POSTFIX_PASSWORD}';
GRANT ALL PRIVILEGES ON postfix.* TO 'postfix'@'localhost';
FLUSH PRIVILEGES;
EOSQL
    sed -i "s|inet_interfaces = localhost|inet_interfaces = all|" /etc/postfix/main.cf
    sed -i "s|#home_mailbox = Maildir/|home_mailbox = Maildir/|" /etc/postfix/main.cf
    systemctl enable postfix dovecot && systemctl restart postfix dovecot
    log "Mail server installed"
}

save_creds() {
    local f="/root/.openpanel-credentials"
    cat > "$f" <<EOF
# OpenPanel Credentials - Generated $(date)
Panel URL:       https://${SERVER_IP}:2087
Admin User:      ${ADMIN_USER}
Admin Email:     ${ADMIN_EMAIL}
Admin Password:  ${ADMIN_PASSWORD}
MySQL Root Pwd:  ${MYSQL_ROOT_PASSWORD}
OpenPanel DB User:     ${DB_USER}
OpenPanel DB Password: ${DB_PASSWORD}
OpenPanel Database:    ${DB_NAME}
Install Dir:     ${INSTALL_DIR}
EOF
    chmod 600 "$f"
    log "Credentials saved to $f"
}

print_summary() {
    echo ""
    echo -e "${GREEN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║       OpenPanel EL8 Installation Complete!                   ║${NC}"
    echo -e "${GREEN}╠══════════════════════════════════════════════════════════════╣${NC}"
    echo -e "${GREEN}║${NC}  URL:       ${BLUE}https://${SERVER_IP}:2087${NC}"
    echo -e "${GREEN}║${NC}  User:      ${YELLOW}${ADMIN_USER}${NC}"
    echo -e "${GREEN}║${NC}  Password:  ${YELLOW}${ADMIN_PASSWORD}${NC}"
    echo -e "${GREEN}║${NC}  MySQL Pwd: ${YELLOW}${MYSQL_ROOT_PASSWORD}${NC}"
    echo -e "${GREEN}║${NC}  Creds:     /root/.openpanel-credentials"
    echo -e "${GREEN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    [[ "$DO_RESTART" =~ ^[Yy]$ ]] && { log "Rebooting in 10s..."; sleep 10; reboot; }
}

main() {
    echo ""
    echo -e "${BLUE}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║       OpenPanel - EL8 Installer v1.0.0                       ║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""

    check_root
    validate_el8
    check_existing
    check_resources
    gather_config
    install_repos
    install_php
    install_nginx
    install_mariadb
    install_composer
    install_nodejs
    clone_and_setup
    configure_services
    install_csf
    install_mail
    save_creds
    print_summary
}

main "$@"
